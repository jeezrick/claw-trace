{
  "name": "openclaw-trace-service",
  "version": "1.0.0",
  "private": true,
  "description": "Session trace web service for OpenClaw",
  "main": "server.js",
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "start": "node server.js",
    "v2:server:dev": "npm run dev --workspace @claw-trace/server",
    "v2:server:dev:lan": "HOST=0.0.0.0 npm run dev --workspace @claw-trace/server",
    "v2:server:start": "npm run start --workspace @claw-trace/server",
    "v2:server:build": "npm run build --workspace @claw-trace/server",
    "v2:web:dev": "npm run dev --workspace @claw-trace/web",
    "v2:web:dev:fixed": "npm run dev --workspace @claw-trace/web -- --host 127.0.0.1 --port 5174 --strictPort",
    "v2:web:dev:lan": "npm run dev --workspace @claw-trace/web -- --host 0.0.0.0 --port 5174 --strictPort",
    "v2:web:build": "npm run build --workspace @claw-trace/web",
    "v2:build": "npm run v2:server:build && npm run v2:web:build",
    "v2:dev": "bash -lc 'trap \"kill 0\" EXIT; npm run v2:server:dev & npm run v2:web:dev:fixed & wait -n'",
    "v2:dev:lan": "bash -lc 'trap \"kill 0\" EXIT; npm run v2:server:dev:lan & npm run v2:web:dev:lan & wait -n'"
  },
  "engines": {
    "node": ">=18"
  }
}
